# ####################################################################
# DEPENDENCIES (Folder ini sangat berat dan diunduh via 'npm install')
# ####################################################################
node_modules/
jspm_packages/
web_modules/

# ####################################################################
# CONFIGURATION & SECRETS (SANGAT PENTING: Berisi password & API Key)
# ####################################################################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.json

# ####################################################################
# LOGS (File catatan error otomatis dari npm/node)
# ####################################################################
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ####################################################################
# SYSTEM & IDE FILES (File otomatis dari Windows atau VS Code Anda)
# ####################################################################
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ####################################################################
# PRODUCTION/BUILD OUTPUT (Gunakan jika Anda memakai TypeScript/Babel)
# ####################################################################
dist/
build/

# ####################################################################
# TESTING & COVERAGE (Jika nanti Anda membuat unit testing)
# ####################################################################
coverage/
*.lcov