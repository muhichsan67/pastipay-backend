<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — PastiPay Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #1a1a2e;
            --sidebar-accent: #0d6efd;
            --topbar-height: 60px;
        }
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }

        /* Sidebar */
        #sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-width); height: 100vh;
            background: var(--sidebar-bg);
            display: flex; flex-direction: column;
            z-index: 1000; transition: transform .3s ease;
            overflow-y: auto;
        }
        .sidebar-brand {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.08);
            display: flex; align-items: center; gap: .75rem;
        }
        .sidebar-brand .brand-icon {
            width: 38px; height: 38px; border-radius: 10px;
            background: var(--sidebar-accent);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white; flex-shrink: 0;
        }
        .sidebar-brand span { color: white; font-weight: 700; font-size: 1.05rem; }
        .sidebar-nav { padding: 1rem 0; flex: 1; }
        .nav-section-label {
            font-size: .68rem; font-weight: 700; letter-spacing: 1px;
            color: rgba(255,255,255,.35); text-transform: uppercase;
            padding: .5rem 1.5rem .25rem;
        }
        .sidebar-link {
            display: flex; align-items: center; gap: .75rem;
            padding: .65rem 1.5rem; color: rgba(255,255,255,.65);
            text-decoration: none; font-size: .9rem; font-weight: 500;
            transition: all .2s; border-left: 3px solid transparent;
        }
        .sidebar-link:hover { color: white; background: rgba(255,255,255,.07); }
        .sidebar-link.active {
            color: white; background: rgba(13,110,253,.2);
            border-left-color: var(--sidebar-accent);
        }
        .sidebar-link i { font-size: 1rem; width: 20px; text-align: center; }

        /* Main layout */
        #main-wrapper {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }

        /* Topbar */
        #topbar {
            height: var(--topbar-height);
            background: white;
            border-bottom: 1px solid #e9ecef;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 1.5rem;
            position: sticky; top: 0; z-index: 999;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }
        .topbar-left { display: flex; align-items: center; gap: .75rem; }
        .topbar-right { display: flex; align-items: center; gap: .75rem; }
        .admin-badge {
            display: flex; align-items: center; gap: .5rem;
            background: #f8f9fa; border-radius: 50px;
            padding: .35rem .85rem; font-size: .85rem; font-weight: 600;
        }
        .admin-badge .avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--sidebar-accent); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: .7rem; font-weight: 700;
        }

        /* Page content */
        #page-content { padding: 1.75rem; flex: 1; }

        /* Cards */
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
        .card-header { background: white; border-bottom: 1px solid #f0f2f5; border-radius: 12px 12px 0 0 !important; padding: 1rem 1.25rem; }

        /* Tables */
        .table th { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #6c757d; border-top: none; }
        .table td { vertical-align: middle; font-size: .88rem; }
        .table-hover tbody tr:hover { background: #f8f9ff; }

        /* Badges */
        .badge-pending { background: #fff3cd; color: #664d03; }
        .badge-processed { background: #d1e7dd; color: #0a3622; }
        .badge-closed { background: #f8d7da; color: #58151c; }

        /* Page title */
        .page-title { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; }
        .page-subtitle { font-size: .85rem; color: #6c757d; }

        /* Stats cards */
        .stat-card { border-radius: 12px; border: none; overflow: hidden; }
        .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Toast notification */
        .toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 9999; }

        /* Star rating */
        .stars { color: #ffc107; }
        .stars-empty { color: #dee2e6; }

        @media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.show { transform: translateX(0); }
            #main-wrapper { margin-left: 0; }
        }
    </style>
</head>
<body>

<!-- Sidebar -->
<%- include('partials/sidebar', { activeTab: tab }) %>

<!-- Main Wrapper -->
<div id="main-wrapper">

    <!-- Topbar -->
    <%- include('partials/header', { name: adminName }) %>

    <!-- Toast Notification -->
    <% if(message) { %>
    <div class="toast-container">
        <div class="toast show align-items-center text-bg-<%= msgType === 'warning' ? 'warning' : 'success' %> border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <i class="bi bi-<%= msgType === 'warning' ? 'exclamation-triangle' : 'check-circle' %>-fill"></i>
                    <strong><%= message %></strong>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Page Content -->
    <div id="page-content">
        <% if (tab === 'rates') { %>
            <%- include('partials/menu-rates', { rates: data.rates }) %>
        <% } else if (tab === 'testimonials') { %>
            <%- include('partials/menu-testimonials', { testimonials: data.testimonials, editData: editData }) %>
        <% } else if (tab === 'faqs') { %>
            <%- include('partials/menu-faqs', { faqs: data.faqs, editData: editData }) %>
        <% } else if (tab === 'contacts') { %>
            <%- include('partials/menu-contacts', { contacts: data.contacts }) %>
        <% } %>
    </div>

</div><!-- /main-wrapper -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Auto-dismiss toast after 4 seconds
    document.querySelectorAll('.toast').forEach(t => {
        setTimeout(() => { const bsToast = bootstrap.Toast.getOrCreateInstance(t); bsToast.hide(); }, 4000);
    });
</script>
</body>
</html>
